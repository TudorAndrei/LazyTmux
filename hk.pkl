amends "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.50.0/hk@1.50.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    ["stylua"] = Builtins.stylua
    ["luacheck"] = Builtins.luacheck
}

local commit_msg_linters = new Mapping<String, Step> {
    ["check_conventional_commit"] = Builtins.check_conventional_commit
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = linters
    }
    ["commit-msg"] {
        steps = commit_msg_linters
    }
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
