#!/usr/bin/env sh
set -eu

if command -v luacheck >/dev/null 2>&1; then
  luacheck_bin="luacheck"
elif [ -x "$HOME/.local/share/mise/installs/lua/5.1/luarocks/bin/luacheck" ]; then
  luacheck_bin="$HOME/.local/share/mise/installs/lua/5.1/luarocks/bin/luacheck"
else
  printf '%s\n' "luacheck was not found. Install it with: luarocks install luacheck" >&2
  exit 127
fi

if [ "$#" -gt 0 ]; then
  "$luacheck_bin" "$@"
else
  "$luacheck_bin" lua plugins statusline themes
fi
